                        record.ShipToAddress2 = selectedRecord.Edi850Record.ShipToAddress2;
                        record.ShipToAttention = selectedRecord.Edi850Record.ShipToAttention;
                        record.ShipToCity = selectedRecord.Edi850Record.ShipToCity;
                        record.ShipToCountry = selectedRecord.Edi850Record.ShipToCountry;
