        private DeliveryLine FindMatchingDelivery(WebApiDbContext context, Edi850Record record)
        {
            return (from v in context.DeliveryLines.Include("Delivery")
                    where v.BaseType == 17
                        && v.BaseEntry == record.SalesOrderKey
                        && v.LineNumber850 == record.LineNumber
                        && v.Delivery.Canceled == "N"
                    select v).FirstOrDefault();
        }
