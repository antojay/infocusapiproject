        private InvoiceLine FindMatchingInvoice(WebApiDbContext context, Edi850Record record)
        {
            var deliveryLine = FindMatchingDelivery(context, record);
            if(deliveryLine == null)
            {
                return null;
            }
            return (from v in context.InvoiceLines.Include("Invoice")
                    where v.BaseType == 15
                        && v.BaseEntry == deliveryLine.DocEntry
                        && v.LineNumber850 == record.LineNumber
                        && v.Invoice.Canceled == "N"
                    select v).FirstOrDefault();
        }
