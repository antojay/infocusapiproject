                        record.PromotionChargeCode = selectedRecord.Edi850Record.PromotionChargeCode;
                        record.PurchaseOrderDate = selectedRecord.Edi850Record.PurchaseOrderDate;
                        record.PurchaseOrderReference = selectedRecord.Edi850Record.PurchaseOrderReference;
                        record.Quantity = selectedRecord.Edi850Record.Quantity;
                        record.ReplenishmentNumber = selectedRecord.Edi850Record.ReplenishmentNumber;
