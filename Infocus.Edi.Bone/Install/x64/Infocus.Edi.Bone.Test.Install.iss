function GetDefaultAddOnDir(Param : string): string;
begin
  //-Default Directory to Install the Add-On
     result := InstallDirectoryPath;
end;

//-When Setup starts, get the parameters of B1
function ParseCommandLineArguments() : Boolean;
  var
    commandLineArgs : string;
    positionOfToken : Integer;
  begin
    //MsgBox('Entering ParseCommandLineArguments', mbInformation, MB_OK);
    //-First Check if the application is installed
    //MsgBox('JBB  :' + GetCmdTail, mbInformation, MB_OK)
    //MsgBox('JBB# :' + IntToStr(ParamCount), mbInformation, MB_OK)
    //commandLineArgs := GetCmdTail;
    if ParamCount > 1 then
    begin
      if IsRunningInBusinessOne then
      begin
        commandLineArgs := ParamStr(ParamCount);       		
        if pos('/uninstall', GetCmdTail) <> 0 then
        begin
          //MsgBox('IsUninstall = true.', mbInformation, MB_OK);
          IsUninstall := True;
        end
        else
        begin
          //MsgBox('IsUninstall = false.', mbInformation, MB_OK);
          IsUninstall := False;		
          StringChangeEx(commandLineArgs, '/z', '', True);
          StringChangeEx(commandLineArgs, '"', '', True); 
          commandLineArgs := Trim(commandLineArgs);
          positionOfToken := Pos('|', commandLineArgs);
          InstallDirectoryPath := Copy(commandLineArgs, 1, positionOfToken - 1);
          BusinessOneApiPath := Copy(commandLineArgs, positionOfToken + 1, 9999999);
        end
        result := True;
      end
      else
      begin
        MsgBox('This installer must be invoked by SAP Business One (10).', mbInformation, MB_OK);
        result := False;
      end
    end
    else
    begin
      IsRunningInBusinessOne := False;
      MsgBox('This installer must be invoked by SAP Business One (11).', mbInformation, MB_OK);
      result := False;
    end
  end;

function InitializeSetup(): Boolean;
  begin 
  //MsgBox('Entering InitializeSetup. ' + GetCmdTail, mbInformation, MB_OK);
    if Pos('$$B1ADDONINSTALL$$', GetCmdTail) <> 0 then
    begin
      IsRunningInBusinessOne := True;
      if ParseCommandLineArguments then
      begin
        if IsUninstall then
          begin
            Uninstall;
            result := False;
          end
        else
          begin
            result := True;
          end
      end
      else
        begin                     
          EndInstallEx('', False);
          result := False;                                                  
        end
    end
    else
    begin
      IsRunningInBusinessOne := False;
      MsgBox('This installer must be invoked by SAP Business One (13).', mbInformation, MB_OK);
      result := False;
    end
  end;

