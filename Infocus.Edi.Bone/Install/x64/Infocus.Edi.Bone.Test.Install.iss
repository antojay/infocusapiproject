ArchitecturesInstallIn64BitMode=x64

[Languages]
Name: "english"; MessagesFile: "compiler:Default.isl"

[Files]
Source: "libs\AddOnInstallAPI.dll"; Flags: dontcopy;
;Source: "C:\Users\Joel\Documents\Visual Studio 2015\Projects\Infocus.WebApi\Infocus.Edi.Bone\bin\x64\Release\*"; DestDir: "{app}"; Flags: ignoreversion recursesubdirs createallsubdirs
Source: "C:\Infocus Source\Infocus.WebApi\Infocus.Edi.Bone\bin\x64\Debug\*"; DestDir: "{app}"; Flags: ignoreversion recursesubdirs createallsubdirs
; NOTE: Don't use "Flags: ignoreversion" on any shared system files

[Registry]
Root: HKLM64; Subkey: "{#MyInstallRegistryRoot}"; Flags: uninsdeletekey
Root: HKLM64; Subkey: "{#MyInstallRegistryRoot}\{#MyInstallRegistryKey}"; Flags: uninsdeletekey
Root: HKLM64; Subkey: "{#MyInstallRegistryRoot}\{#MyInstallRegistryKey}"; ValueType: string; ValueName: "InstallPath"; ValueData: "{app}"

[Code]
//-Public Vars
var
  InstallDirectoryPath : string;
  BusinessOneApiPath : string;
  IsUninstall : Boolean;
  FinishedInstall : Boolean;
  IsRunningInBusinessOne : Boolean;

//-External Functions (AddOnInstallAPI.dll)
//function EndInstall: integer; external 'EndInstall@files:AddOnInstallAPI.dll stdcall';
function EndInstallEx(srcPath:string;isSuccess:boolean): integer; external 'EndInstallEx@files:AddOnInstallAPI.dll stdcall';
function EndUninstall(srcPath:string;isSuccess:boolean): integer; external 'EndUninstall@files:AddOnInstallAPI.dll stdcall';
function SetAddOnFolder(srcPath : string): integer; external 'SetAddOnFolder@files:AddOnInstallAPI.dll stdcall';
function RestartNeeded :integer; external 'RestartNeeded@files:AddOnInstallAPI.dll stdcall delayload ';


//-Check if the application is installed;
//- if yes --> suggest to Remove
//- if no --> Install
function Uninstall(): boolean;
  var
    ResultCode: Integer;
  begin
    // MsgBox('Entering Uninstall.', mbInformation, MB_OK);
	  // MsgBox('Current dir is <' + GetCurrentDir + '>', mbInformation, MB_OK);
	// MsgBox(InstallDirectoryPath + '\unins000.exe', mbInformation, MB_OK);
	//Exec(GetCurrentDir + '\unins000.exe', '', '', SW_SHOW, ewWaitUntilTerminated, ResultCode);
    if RegQueryStringValue(HKLM64, '{#MyInstallRegistryRoot}\{#MyInstallRegistryKey}', 'InstallPath', InstallDirectoryPath) then 
    begin
      Exec(InstallDirectoryPath + '\unins000.exe', '', '', SW_SHOW, ewWaitUntilTerminated, ResultCode);
      EndUninstall(InstallDirectoryPath, True);
      //MsgBox('{#MyAppName} was successfully removed.', mbInformation, MB_OK);
      result := True;
    end
    else
    begin
      MsgBox('Could not obtain RegistryKey value for HKLM64\{#MyInstallRegistryRoot}\{#MyInstallRegistryKey}\InstallPath.  Aborting Uninstall.', mbInformation, MB_OK);
      EndUninstall('', False);
      result := False;
    end
  end;

